{
  "compilerOptions": {
    "target": "ES2019",
    "lib": ["ES2019"],
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "types": ["miniprogram-api-typings", "jest"],
    "paths": {
      "@/*": ["miniprogram/*"]
    }
  },
  "include": ["miniprogram/**/*.ts", "tests/**/*.ts"]
}
