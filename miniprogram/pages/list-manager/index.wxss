.manager-page {
  min-height: 100vh;
  padding: 32rpx;
  background: linear-gradient(180deg, #f3eadc 0%, #ecdcca 100%);
}

.manager-card {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  background: #fff8ef;
}

.manager-title {
  font-size: 40rpx;
  font-weight: 700;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.field-label {
  font-size: 24rpx;
  color: #7f7061;
}

.field-input {
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: #f3ebde;
  font-size: 28rpx;
}

.action-button {
  border: none;
  border-radius: 999rpx;
  background: #1f1a16;
  color: #fff8ef;
}

.action-button::after {
  border: none;
}

.list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #f4ecdf;
}

.list-tag {
  font-size: 22rpx;
  color: #7b6c5d;
}
