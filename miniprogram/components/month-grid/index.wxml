<view class="grid">
  <view class="weekday" wx:for="{{['一', '二', '三', '四', '五', '六', '日']}}" wx:key="*this">
    {{item}}
  </view>

  <view
    class="cell {{item.isCurrentMonth ? '' : 'cell--muted'}} {{item.isSelected ? 'cell--selected' : ''}}"
    wx:for="{{cells}}"
    wx:key="dueDateKey"
    data-due-date-key="{{item.dueDateKey}}"
    bindtap="onSelectDay"
  >
    <text class="cell-day">{{item.day}}</text>
    <view class="preview-list">
      <text class="preview-item" wx:for="{{item.previewItems}}" wx:key="*this">{{item}}</text>
      <text class="preview-more" wx:if="{{item.overflowCount > 0}}">+{{item.overflowCount}}</text>
    </view>
  </view>
</view>
