.page {
  min-height: 100vh;
  padding: 24rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 233, 201, 0.9), transparent 32%),
    linear-gradient(180deg, #f5efe3 0%, #ebe0cf 100%);
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  text-align: center;
}

.subtitle {
  font-size: 26rpx;
  color: #6c645c;
  text-align: center;
}

.page-shell {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-bottom: 120rpx;
}

.hero {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 24rpx 8rpx;
}

.hero__eyebrow {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  color: #8f7d67;
}

.hero__title {
  font-size: 56rpx;
  font-weight: 800;
  color: #231b14;
}

.hero__subtitle {
  font-size: 26rpx;
  color: #6b5d4f;
}

.hero__cta {
  align-self: flex-start;
  border: none;
  border-radius: 999rpx;
  background: #f0dcc1;
  color: #241d17;
  padding: 0 28rpx;
}

.hero__cta::after {
  border: none;
}

.fab {
  position: fixed;
  right: 32rpx;
  bottom: 32rpx;
  border: none;
  border-radius: 999rpx;
  padding: 0 36rpx;
  line-height: 88rpx;
  background: #1e1a16;
  color: #fff8ef;
  box-shadow: 0 18rpx 40rpx rgba(30, 26, 22, 0.18);
}

.fab::after {
  border: none;
}
